<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
</head>

<body>
{{if .Name }}
    <p>Hello {{.Name}}</p>
{{else if .LastName}}
    <p>Hello {{.LastName}}</p>
{{else}}
    <p> Hello </p>
{{end}}

<p> Address:  {{.Address.Street}} </p>  {{/*Nested Struct*/}}
</body>

</html>